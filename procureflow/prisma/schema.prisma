generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Auth (NextAuth) ---

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model RefreshToken {
  id         String   @id @default(cuid())
  token      String   @unique
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  expires_at DateTime
  revoked    Boolean  @default(false)
  created_at DateTime @default(now())

  @@index([user_id, revoked])
  @@index([expires_at])
  @@map("refresh_tokens")
}

// --- Core Models ---

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  name          String
  role          UserRole  @default(REQUESTER)
  department    String?
  avatar_url    String?
  password_hash String?
  created_at    DateTime  @default(now())

  // Security: lockout
  failed_login_attempts Int       @default(0)
  locked_until          DateTime?
  last_login_at         DateTime?

  // Security: token rotation
  token_version    Int    @default(0)

  // Security: TOTP MFA
  totp_secret     String?
  totp_enabled    Boolean  @default(false)
  recovery_codes  String[] // Hashed with bcrypt

  // Onboarding
  onboarding_completed Boolean  @default(false)
  onboarding_data      Json?

  accounts         Account[]
  sessions         Session[]
  refresh_tokens   RefreshToken[]
  requests         PurchaseRequest[]
  approvals     Approval[]
  comments      Comment[]
  notifications Notification[]

  tenders_assigned  Tender[]  @relation("TenderAssigned")
  tenders_created   Tender[]  @relation("TenderCreated")

  @@map("users")
}

enum UserRole {
  ADMIN
  MANAGER
  REQUESTER
  VIEWER
}

model Vendor {
  id            String            @id @default(cuid())
  name          String
  code          String            @unique
  email         String?
  phone         String?
  website       String?
  portal_url    String?
  portal_type   VendorPortalType?
  category      String[]
  payment_terms String?
  rating        Float?
  status        VendorStatus      @default(ACTIVE)
  notes         String?
  created_at    DateTime          @default(now())
  updated_at    DateTime          @updatedAt

  vat_id   String?           @unique  // Partita IVA (per matching fatture)

  requests PurchaseRequest[]
  contacts VendorContact[]
  invoices Invoice[]

  tenders_as_authority  Tender[]  @relation("TenderAuthority")

  materials_as_preferred  Material[]  @relation("MaterialPreferredVendor")
  material_alerts         MaterialAlert[]  @relation("MaterialAlertVendor")

  @@map("vendors")
}

enum VendorPortalType {
  WEBSITE
  EMAIL_ONLY
  API
  MARKETPLACE
  PHONE
}

enum VendorStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
  PENDING_REVIEW
}

model VendorContact {
  id        String @id @default(cuid())
  vendor_id String
  vendor    Vendor @relation(fields: [vendor_id], references: [id], onDelete: Cascade)
  name      String
  role      String?
  email     String?
  phone     String?

  @@map("vendor_contacts")
}

model PurchaseRequest {
  id          String        @id @default(cuid())
  code        String        @unique
  title       String
  description String?
  status      RequestStatus @default(DRAFT)
  priority    Priority      @default(MEDIUM)

  requester_id String
  requester    User   @relation(fields: [requester_id], references: [id])
  vendor_id    String?
  vendor       Vendor? @relation(fields: [vendor_id], references: [id])

  estimated_amount  Decimal?  @db.Decimal(12, 2)
  currency          String    @default("EUR")
  actual_amount     Decimal?  @db.Decimal(12, 2)

  needed_by         DateTime?
  ordered_at        DateTime?
  expected_delivery DateTime?
  delivered_at      DateTime?

  email_message_id String?   @unique

  external_ref    String?
  external_url    String?
  tracking_number String?

  // Compliance italiana
  cig             String?       // Codice Identificativo Gara (10 char alfanum)
  cup             String?       // Codice Unico Progetto (15 char alfanum)
  is_mepa         Boolean       @default(false) // Acquisto su MEPA/Consip
  mepa_oda_number String?       // Numero ODA o trattativa diretta MEPA

  // Importi fatturati
  invoiced_amount Decimal?      @db.Decimal(12, 2)

  category    String?
  department  String?
  cost_center String?
  budget_code String?

  tags       String[]
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  items       RequestItem[]
  approvals   Approval[]
  comments    Comment[]
  attachments Attachment[]
  timeline    TimelineEvent[]
  invoices    Invoice[]

  stock_lots         StockLot[]
  stock_reservations StockReservation[]
  stock_movements    StockMovement[]

  @@index([status, created_at])
  @@index([requester_id, status])
  @@index([vendor_id, status])
  @@index([needed_by])
  @@index([department, cost_center])
  @@index([cost_center, status])
  @@map("purchase_requests")
}

enum RequestStatus {
  DRAFT
  SUBMITTED
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ORDERED
  SHIPPED
  DELIVERED
  INVOICED
  RECONCILED
  CLOSED
  CANCELLED
  ON_HOLD
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model RequestItem {
  id          String          @id @default(cuid())
  request_id  String
  request     PurchaseRequest @relation(fields: [request_id], references: [id], onDelete: Cascade)

  name        String
  description String?
  quantity    Int
  unit        String?
  unit_price  Decimal? @db.Decimal(12, 2)
  total_price Decimal? @db.Decimal(12, 2)
  sku         String?

  // IVA per riga
  vat_rate          Decimal? @db.Decimal(5, 2) @default(22.00)
  vat_nature        String?  // Natura operazione se IVA=0 (N1-N7)
  is_split_payment  Boolean  @default(false)
  is_reverse_charge Boolean  @default(false)

  @@map("request_items")
}

model Approval {
  id          String          @id @default(cuid())
  request_id  String
  request     PurchaseRequest @relation(fields: [request_id], references: [id])
  approver_id String
  approver    User            @relation(fields: [approver_id], references: [id])

  status      ApprovalStatus @default(PENDING)
  decision_at DateTime?
  notes       String?

  created_at DateTime @default(now())

  @@map("approvals")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  DELEGATED
}

model TimelineEvent {
  id          String          @id @default(cuid())
  request_id  String?
  request     PurchaseRequest? @relation(fields: [request_id], references: [id], onDelete: Cascade)

  invoice_id  String?
  invoice     Invoice?        @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  type             String
  title            String
  description      String?
  metadata         Json?
  actor            String?
  email_message_id String?

  created_at DateTime @default(now())

  @@index([email_message_id])
  @@index([invoice_id])
  @@map("timeline_events")
}

model Comment {
  id          String          @id @default(cuid())
  request_id  String
  request     PurchaseRequest @relation(fields: [request_id], references: [id], onDelete: Cascade)
  author_id   String
  author      User            @relation(fields: [author_id], references: [id])

  content     String
  is_internal Boolean @default(true)

  created_at DateTime @default(now())

  @@map("comments")
}

model Attachment {
  id          String          @id @default(cuid())
  request_id  String
  request     PurchaseRequest @relation(fields: [request_id], references: [id], onDelete: Cascade)

  filename  String
  file_url  String
  file_size Int?
  mime_type String?

  created_at DateTime @default(now())

  @@map("attachments")
}

model Notification {
  id      String  @id @default(cuid())
  user_id String
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  title String
  body  String
  type  String
  link  String?
  read  Boolean @default(false)

  created_at DateTime @default(now())

  @@index([user_id, read])
  @@map("notifications")
}

// --- Fatturazione Elettronica (SDI) ---

model Invoice {
  id                    String               @id @default(cuid())

  // Identificativi SDI
  sdi_id                String?              @unique
  sdi_filename          String?
  sdi_status            String?              // RECEIVED, ACCEPTED, REJECTED

  xml_raw               String?              @db.Text

  // Dati fattura
  invoice_number        String
  invoice_date          DateTime
  due_date              DateTime?
  document_type         String               @default("TD01") // TD01=Fattura, TD04=Nota credito

  // Importi
  total_taxable         Decimal              @db.Decimal(12, 2)
  total_tax             Decimal              @db.Decimal(12, 2)
  total_amount          Decimal              @db.Decimal(12, 2)
  currency              String               @default("EUR")

  // Fornitore (estratti da XML)
  supplier_vat_id       String
  supplier_tax_code     String?
  supplier_name         String

  // Cliente (nostro tenant)
  customer_vat_id       String

  // Riferimenti per matching
  causale               String?
  external_ref          String?
  pr_code_extracted     String?

  // Pagamento
  payment_method        String?
  payment_terms         String?
  iban                  String?

  // Matching
  match_status          InvoiceMatchStatus   @default(UNMATCHED)
  match_confidence      Float?
  match_candidates      Json?                // Array di request_id candidati
  matched_at            DateTime?
  matched_by            String?

  // Riconciliazione
  reconciliation_status ReconciliationStatus @default(PENDING)
  reconciliation_notes  String?              @db.Text
  reconciled_at         DateTime?
  reconciled_by         String?

  // Discrepanze three-way match
  amount_discrepancy    Decimal?             @db.Decimal(12, 2)
  discrepancy_type      DiscrepancyType?
  discrepancy_resolved  Boolean              @default(false)

  // Relazioni
  vendor_id             String?
  vendor                Vendor?              @relation(fields: [vendor_id], references: [id])
  purchase_request_id   String?
  purchase_request      PurchaseRequest?     @relation(fields: [purchase_request_id], references: [id])
  tenant_id             String               @default("default")

  line_items            InvoiceLineItem[]
  timeline_events       TimelineEvent[]

  received_at           DateTime             @default(now())
  created_at            DateTime             @default(now())
  updated_at            DateTime             @updatedAt

  @@index([supplier_vat_id])
  @@index([pr_code_extracted])
  @@index([match_status])
  @@index([reconciliation_status])
  @@index([tenant_id])
  @@index([invoice_date])
  @@index([purchase_request_id])
  @@map("invoices")
}

model InvoiceLineItem {
  id              String   @id @default(cuid())

  invoice_id      String
  invoice         Invoice  @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  line_number     Int
  description     String
  quantity        Decimal  @db.Decimal(12, 4)
  unit_of_measure String?
  unit_price      Decimal  @db.Decimal(12, 4)
  total_price     Decimal  @db.Decimal(12, 2)

  // IVA per riga
  vat_rate        Decimal  @db.Decimal(5, 2)
  vat_amount      Decimal? @db.Decimal(12, 2)
  vat_nature      String?  // Natura operazione se IVA=0 (N1-N7)

  // Matching con riga ordine
  matched_item_id String?

  created_at      DateTime @default(now())

  @@map("invoice_line_items")
}

enum InvoiceMatchStatus {
  UNMATCHED
  AUTO_MATCHED
  SUGGESTED
  MANUALLY_MATCHED
  NO_MATCH
}

enum ReconciliationStatus {
  PENDING
  MATCHED
  APPROVED
  DISPUTED
  REJECTED
  PAID
}

enum DiscrepancyType {
  AMOUNT_MISMATCH
  QUANTITY_MISMATCH
  PRICE_MISMATCH
  ITEM_MISMATCH
  NONE
}

// --- Budget Management ---

enum BudgetPeriodType {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum BudgetEnforcementMode {
  SOFT
  HARD
}

model Budget {
  id                      String                @id @default(cuid())
  cost_center             String
  department              String?
  period_type             BudgetPeriodType
  period_start            DateTime
  period_end              DateTime
  allocated_amount        Decimal               @db.Decimal(12, 2)
  alert_threshold_percent Int                   @default(80)
  enforcement_mode        BudgetEnforcementMode @default(SOFT)
  notes                   String?
  is_active               Boolean               @default(true)

  created_by              String
  created_at              DateTime              @default(now())
  updated_at              DateTime              @updatedAt

  snapshots               BudgetSnapshot[]

  @@index([cost_center, period_start, period_end])
  @@index([is_active, cost_center])
  @@map("budgets")
}

model BudgetSnapshot {
  id          String   @id @default(cuid())
  budget_id   String
  budget      Budget   @relation(fields: [budget_id], references: [id], onDelete: Cascade)

  spent       Decimal  @db.Decimal(12, 2)
  committed   Decimal  @db.Decimal(12, 2)
  available   Decimal  @db.Decimal(12, 2)
  computed_at DateTime @default(now())

  @@index([budget_id, computed_at])
  @@map("budget_snapshots")
}

// --- Deploy Configuration ---

model DeployConfig {
  id              String   @id @default("default")
  deploy_name     String   @default("ProcureFlow")
  enabled_modules String[] // ["core", "invoicing", "budgets", ...]
  company_logo_url String?
  categories       String[]
  approval_rules   Json?
  created_at       DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("deploy_config")
}

// --- Tenders (Gare d'Appalto) ---

enum TenderStatus {
  DISCOVERED
  EVALUATING
  GO
  NO_GO
  PREPARING
  SUBMITTED
  UNDER_EVALUATION
  WON
  LOST
  AWARDED
  CANCELLED
  WITHDRAWN
}

enum TenderType {
  OPEN
  RESTRICTED
  NEGOTIATED
  DIRECT_AWARD
  MEPA
  FRAMEWORK
  PRIVATE
}

enum TenderDocumentType {
  BANDO
  CAPITOLATO
  DISCIPLINARE
  ALLEGATO
  OFFERTA_TECNICA
  OFFERTA_ECONOMICA
  CAUZIONE
  DGUE
  CONTRATTO
  VERBALE
  ALTRO
}

enum GoNoGoDecision {
  PENDING
  GO
  NO_GO
}

model Tender {
  id                        String          @id @default(cuid())
  code                      String          @unique  // GARA-2026-00001
  title                     String
  description               String?         @db.Text
  status                    TenderStatus    @default(DISCOVERED)
  tender_type               TenderType

  contracting_authority_id  String?
  contracting_authority     Vendor?         @relation("TenderAuthority", fields: [contracting_authority_id], references: [id])

  cig                       String?
  cup                       String?
  gara_number               String?
  lotto_number              String?
  platform_url              String?
  anac_id                   String?

  base_amount               Decimal?        @db.Decimal(12, 2)
  our_offer_amount          Decimal?        @db.Decimal(12, 2)
  awarded_amount            Decimal?        @db.Decimal(12, 2)
  currency                  String          @default("EUR")

  go_no_go                  GoNoGoDecision  @default(PENDING)
  go_no_go_score            Int?
  go_no_go_notes            String?         @db.Text
  go_no_go_decided_by       String?
  go_no_go_decided_at       DateTime?

  publication_date          DateTime?
  question_deadline         DateTime?
  submission_deadline       DateTime?
  opening_date              DateTime?
  award_date                DateTime?
  contract_start_date       DateTime?
  contract_end_date         DateTime?

  award_criteria            String?
  technical_weight          Int?
  economic_weight           Int?

  our_technical_score       Decimal?        @db.Decimal(5, 2)
  our_economic_score        Decimal?        @db.Decimal(5, 2)
  our_total_score           Decimal?        @db.Decimal(5, 2)
  winner_name               String?
  winner_amount             Decimal?        @db.Decimal(12, 2)
  participants_count        Int?

  category                  String?
  department                String?
  cost_center               String?
  tags                      String[]

  assigned_to_id            String?
  assigned_to               User?           @relation("TenderAssigned", fields: [assigned_to_id], references: [id])
  created_by_id             String
  created_by                User            @relation("TenderCreated", fields: [created_by_id], references: [id])

  notes                     String?         @db.Text
  created_at                DateTime        @default(now())
  updated_at                DateTime        @updatedAt

  documents                 TenderDocument[]
  timeline                  TenderTimeline[]

  stock_reservations  StockReservation[]
  stock_movements     StockMovement[]

  @@index([status, submission_deadline])
  @@index([status, created_at])
  @@index([cig])
  @@index([contracting_authority_id, status])
  @@index([assigned_to_id, status])
  @@map("tenders")
}

model TenderDocument {
  id              String              @id @default(cuid())
  tender_id       String
  tender          Tender              @relation(fields: [tender_id], references: [id], onDelete: Cascade)
  document_type   TenderDocumentType
  filename        String
  file_url        String
  file_size       Int?
  mime_type       String?
  version         Int                 @default(1)
  notes           String?
  uploaded_by     String?
  created_at      DateTime            @default(now())

  @@index([tender_id, document_type])
  @@map("tender_documents")
}

model TenderTimeline {
  id              String    @id @default(cuid())
  tender_id       String
  tender          Tender    @relation(fields: [tender_id], references: [id], onDelete: Cascade)
  type            String
  title           String
  description     String?
  metadata        Json?
  actor           String?
  created_at      DateTime  @default(now())

  @@index([tender_id, created_at])
  @@map("tender_timeline")
}

// --- Inventory (Magazzino) ---

enum StockLotStatus {
  AVAILABLE
  RESERVED
  DEPLETED
  EXPIRED
}

enum StockReservationStatus {
  ACTIVE
  FULFILLED
  CANCELLED
}

enum StockMovementType {
  INBOUND
  OUTBOUND
  TRANSFER
  ADJUSTMENT
  RETURN
}

enum MovementReason {
  ACQUISTO
  RESO_CLIENTE
  PRODUZIONE
  TRASFERIMENTO_IN
  RETTIFICA_POSITIVA
  VENDITA
  RESO_FORNITORE
  TRASFERIMENTO_OUT
  RETTIFICA_NEGATIVA
  SCARTO
  INVENTARIO
  CORREZIONE_MANUALE
}

enum StockInventoryStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Material {
  id                    String    @id @default(cuid())
  code                  String    @unique
  name                  String
  description           String?   @db.Text
  category              String?
  subcategory           String?
  unit_primary          String
  unit_secondary        String?
  conversion_factor     Decimal?  @db.Decimal(12, 6)
  min_stock_level       Decimal?  @db.Decimal(12, 3)
  max_stock_level       Decimal?  @db.Decimal(12, 3)
  unit_cost             Decimal   @default(0) @db.Decimal(12, 4)
  barcode               String?
  qr_code               String?
  preferred_vendor_id   String?
  preferred_vendor      Vendor?   @relation("MaterialPreferredVendor", fields: [preferred_vendor_id], references: [id])
  is_active             Boolean   @default(true)
  tags                  String[]
  notes                 String?   @db.Text
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  lots                  StockLot[]
  movements             StockMovement[]
  reservations          StockReservation[]
  inventory_lines       StockInventoryLine[]
  alerts                MaterialAlert[]

  @@index([category, is_active])
  @@index([code])
  @@index([barcode])
  @@map("materials")
}

model Warehouse {
  id          String          @id @default(cuid())
  code        String          @unique
  name        String
  address     String?
  is_active   Boolean         @default(true)
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt

  zones       WarehouseZone[]
  lots        StockLot[]
  movements   StockMovement[]
  inventories StockInventory[]

  @@map("warehouses")
}

model WarehouseZone {
  id            String    @id @default(cuid())
  warehouse_id  String
  warehouse     Warehouse @relation(fields: [warehouse_id], references: [id], onDelete: Cascade)
  code          String
  name          String
  created_at    DateTime  @default(now())

  lots            StockLot[]
  movements       StockMovement[]
  inventory_lines StockInventoryLine[]

  @@unique([warehouse_id, code])
  @@map("warehouse_zones")
}

model StockLot {
  id                         String          @id @default(cuid())
  lot_number                 String          @unique
  material_id                String
  material                   Material        @relation(fields: [material_id], references: [id])
  warehouse_id               String
  warehouse                  Warehouse       @relation(fields: [warehouse_id], references: [id])
  zone_id                    String?
  zone                       WarehouseZone?  @relation(fields: [zone_id], references: [id])
  initial_quantity           Decimal         @db.Decimal(12, 3)
  current_quantity           Decimal         @db.Decimal(12, 3)
  initial_quantity_secondary Decimal?        @db.Decimal(12, 3)
  current_quantity_secondary Decimal?        @db.Decimal(12, 3)
  unit_cost                  Decimal         @db.Decimal(12, 4)
  expiry_date                DateTime?
  status                     StockLotStatus  @default(AVAILABLE)
  purchase_request_id        String?
  purchase_request           PurchaseRequest? @relation(fields: [purchase_request_id], references: [id])
  notes                      String?
  created_at                 DateTime        @default(now())
  updated_at                 DateTime        @updatedAt

  movements     StockMovement[]
  reservations  StockReservation[]
  inventory_lines StockInventoryLine[]

  @@index([material_id, status])
  @@index([warehouse_id, zone_id])
  @@index([lot_number])
  @@index([purchase_request_id])
  @@map("stock_lots")
}

model StockReservation {
  id                          String                  @id @default(cuid())
  material_id                 String
  material                    Material                @relation(fields: [material_id], references: [id])
  lot_id                      String?
  lot                         StockLot?               @relation(fields: [lot_id], references: [id])
  reserved_quantity           Decimal                 @db.Decimal(12, 3)
  reserved_quantity_secondary Decimal?                @db.Decimal(12, 3)
  tender_id                   String?
  tender                      Tender?                 @relation(fields: [tender_id], references: [id])
  purchase_request_id         String?
  purchase_request            PurchaseRequest?        @relation(fields: [purchase_request_id], references: [id])
  status                      StockReservationStatus  @default(ACTIVE)
  reserved_by                 String?
  reserved_at                 DateTime                @default(now())
  expires_at                  DateTime?
  fulfilled_at                DateTime?
  notes                       String?

  @@index([material_id, status])
  @@index([tender_id])
  @@index([purchase_request_id])
  @@map("stock_reservations")
}

model StockMovement {
  id                    String            @id @default(cuid())
  code                  String            @unique
  material_id           String
  material              Material          @relation(fields: [material_id], references: [id])
  lot_id                String?
  lot                   StockLot?         @relation(fields: [lot_id], references: [id])
  warehouse_id          String
  warehouse             Warehouse         @relation(fields: [warehouse_id], references: [id])
  zone_id               String?
  zone                  WarehouseZone?    @relation(fields: [zone_id], references: [id])
  movement_type         StockMovementType
  reason                MovementReason
  quantity              Decimal           @db.Decimal(12, 3)
  quantity_secondary    Decimal?          @db.Decimal(12, 3)
  unit_cost             Decimal?          @db.Decimal(12, 4)
  to_warehouse_id       String?
  to_zone_id            String?
  purchase_request_id   String?
  purchase_request      PurchaseRequest?  @relation(fields: [purchase_request_id], references: [id])
  tender_id             String?
  tender                Tender?           @relation(fields: [tender_id], references: [id])
  reference_code        String?
  notes                 String?
  actor                 String?
  created_at            DateTime          @default(now())
  inventory_line_id     String?

  @@index([material_id, created_at])
  @@index([warehouse_id, created_at])
  @@index([movement_type, created_at])
  @@index([purchase_request_id])
  @@index([tender_id])
  @@map("stock_movements")
}

model StockInventory {
  id              String                @id @default(cuid())
  code            String                @unique
  warehouse_id    String
  warehouse       Warehouse             @relation(fields: [warehouse_id], references: [id])
  status          StockInventoryStatus  @default(DRAFT)
  notes           String?
  started_at      DateTime?
  completed_at    DateTime?
  completed_by    String?
  created_by      String
  created_at      DateTime              @default(now())
  updated_at      DateTime              @updatedAt

  lines           StockInventoryLine[]

  @@index([warehouse_id, status])
  @@map("stock_inventories")
}

model StockInventoryLine {
  id                     String          @id @default(cuid())
  inventory_id           String
  inventory              StockInventory  @relation(fields: [inventory_id], references: [id], onDelete: Cascade)
  material_id            String
  material               Material        @relation(fields: [material_id], references: [id])
  lot_id                 String?
  lot                    StockLot?       @relation(fields: [lot_id], references: [id])
  zone_id                String?
  zone                   WarehouseZone?  @relation(fields: [zone_id], references: [id])
  expected_quantity      Decimal         @db.Decimal(12, 3)
  counted_quantity       Decimal?        @db.Decimal(12, 3)
  variance               Decimal?        @db.Decimal(12, 3)
  adjustment_movement_id String?

  @@index([inventory_id])
  @@map("stock_inventory_lines")
}

// --- AI Insights & Material Alerts ---

enum InsightType {
  SPEND_ANOMALY
  VENDOR_RISK
  SAVINGS
  BOTTLENECK
  BUDGET_ALERT
}

enum InsightSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertType {
  REORDER_SUGGESTED
  LOW_STOCK
  OUT_OF_STOCK
}

model AiInsight {
  id           String          @id @default(cuid())
  type         InsightType
  severity     InsightSeverity
  title        String
  description  String
  action_label String?
  action_url   String?
  metadata     Json?
  dismissed    Boolean         @default(false)
  expires_at   DateTime
  created_at   DateTime        @default(now())

  @@index([dismissed, expires_at])
  @@index([type, severity])
  @@map("ai_insights")
}

model MaterialAlert {
  id                  String    @id @default(cuid())
  material_id         String
  material            Material  @relation(fields: [material_id], references: [id])
  type                AlertType
  suggested_qty       Int?
  suggested_vendor_id String?
  suggested_vendor    Vendor?   @relation("MaterialAlertVendor", fields: [suggested_vendor_id], references: [id])
  days_remaining      Float?
  dismissed           Boolean   @default(false)
  resolved_by         String?
  created_at          DateTime  @default(now())

  @@index([material_id, dismissed])
  @@map("material_alerts")
}

// --- Webhook Idempotency ---

model ProcessedWebhook {
  id          String   @id @default(cuid())
  webhook_id  String   @unique
  endpoint    String
  status_code Int
  response    Json?
  created_at  DateTime @default(now())

  @@index([created_at])
  @@map("processed_webhooks")
}
