# === ProcureFlow Production Environment ===

# Database (used by app container)
POSTGRES_PASSWORD=change-me-strong-password

# Auth
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# n8n Integration
N8N_WEBHOOK_BASE_URL=http://n8n:5678/webhook
N8N_WEBHOOK_SECRET=your-hmac-secret
N8N_USER=admin
N8N_PASSWORD=change-me
N8N_EXTERNAL_URL=https://n8n.your-domain.com

# AI (optional)
ANTHROPIC_API_KEY=sk-ant-...

# Encryption for integration credentials (64 hex chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Seed demo data on first startup (set to false after first run)
SEED_ON_STARTUP=true
