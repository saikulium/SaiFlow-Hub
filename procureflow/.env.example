# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/procureflow

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# n8n Integration
N8N_WEBHOOK_BASE_URL=https://n8n.yourdomain.com/webhook
N8N_WEBHOOK_SECRET=your-hmac-secret

# File Storage (S3 compatible)
S3_ENDPOINT=
S3_BUCKET=procureflow-attachments
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Optional: AI for email parsing
ANTHROPIC_API_KEY=

# Optional: Email
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# SDI (Fatturazione Elettronica)
SDI_PROVIDER=custom
SDI_API_BASE_URL=
SDI_API_KEY=
SDI_WEBHOOK_SECRET=your-sdi-hmac-secret

# Encryption key for integration credentials (32 bytes = 64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
